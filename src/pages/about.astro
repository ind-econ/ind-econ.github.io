  }

  h1 {
    font-size: 3rem;
  }

  h2 {
    font-size: 2rem;
    margin-top: 3rem;
    margin-bottom: 1.5rem;
    color: var(--text-primary);
  }

  h3 {
    font-size: 1.5rem;
    margin-bottom: 1rem;
    color: var(--text-secondary);
  }

  .content-wrapper {
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--text-secondary);
  }

  .content-wrapper p {
    margin-bottom: 1.5rem;
  }

  .divider {
    border: none;
