---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import EventCard from "../components/EventCard.astro";

const upcomingEvents = [
  {
    title: "NIE Conference & PhD Symposium 2026",
    date: "June 25-26, 2026",
    location: "University of Sheffield School of Economics",
    type: "conference" as const,
    description:
      "The 2026 NIE Conference and PhD Symposium will be hosted at the University of Sheffield School of Economics on June 25th and 26th.",
    link: "/conference2026",
  },
];

const pastEvents = [
  {
    title: "NIE Conference & PhD Symposium 2025",
    date: "June 26-27, 2025",
    location: "Nottingham University Business School",
    type: "conference" as const,
    description:
      "The 2025 Annual Conference features presentations by leading industrial economists including Luke Garrod, Rajssa Mechelli, Joel Stiebale, Tommaso Valletti, and Marit Hinnosaar. The PhD Symposium will be held on the 26th.",
    link: "/conference2025",
  },
  {
    title: "NIE Conference & PhD Symposium 2024",
    date: "June 27-28, 2024",
    location: "University of Warwick",
    type: "conference" as const,
    description:
      "The 2024 Symposium and Conference took place at the University of Warwick, continuing our tradition of fostering impactful research discussions.",
    link: "/conference2024",
  },
  {
    title: "NIE Conference & PhD Symposium 2023",
    date: "June 8-9, 2023",
    location: "University of Leicester",
    type: "conference" as const,
    description:
      "The 2023 Conference and PhD Symposium were successfully hosted at the University of Leicester School of Business.",
    link: "/conference2023",
  },
  {
    title: "NIE Conference & PhD Symposium 2022",
    date: "July 7-8, 2022",
    location: "Loughborough University",
    type: "conference" as const,
    description:
      "The 2022 Conference and PhD Symposium were hosted at the School of Business and Economics at Loughborough University.",
    link: "/conference2022",
  },
];
---

<Layout title="Network of Industrial Economists | Home">
  <Hero />

  <section id="about" class="section about-section">
    <div class="container">
      <div class="about-grid">
        <div class="about-content animate-fade-up">
          <h2 class="section-title">
            About <span class="text-gradient">NIE</span>
          </h2>
          <p class="lead">
            The Network of Industrial Economists is a forum for interchange
            among university economists in the UK and the world and for
            interaction between academia, business, and government on topics of
            industry economics.
          </p>
          <p>
            Established as a study group in the 1970s, the NIE has grown into a
            major forum for interchange about research, and two-way interaction
            between researchers and members from business, consultancy, and
            government agencies. We host annual main meetings and targeted
            symposiums.
          </p>
          <div class="stats-grid">
            <div class="stat-box">
              <span class="stat-number">50+</span>
              <span class="stat-label">Years of Excellence</span>
            </div>
            <div class="stat-box">
              <span class="stat-number">2+</span>
              <span class="stat-label">Meetings Annually</span>
            </div>
            <div class="stat-box">
              <span class="stat-number">400+</span>
              <span class="stat-label">Members</span>
            </div>
          </div>
        </div>
        <div class="about-visual animate-fade-up delay-200">
          <!-- Abstract representation of data/economics -->
          <div class="glass-panel">
            <div class="chart-bars">
              <div class="bar b1"></div>
              <div class="bar b2"></div>
              <div class="bar b3"></div>
              <div class="bar b4"></div>
              <div class="bar b5"></div>
            </div>
            <div class="trend-line"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="upcoming-events" class="section events-section">
    <div class="container">
      <div class="section-header animate-fade-up">
        <h2 class="section-title">
          Upcoming <span class="text-gradient">Events</span>
        </h2>
        <p>Join us at our upcoming academic gatherings across the UK.</p>
      </div>

      <div class="events-grid">
        {
          upcomingEvents.map((event, index) => (
            <div class={`animate-fade-up delay-${(index + 1) * 100}`}>
              <EventCard {...event} />
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section id="past-events" class="section events-section past-events-section">
    <div class="container">
      <div class="section-header animate-fade-up">
        <h2 class="section-title">
          Past <span class="text-gradient">Events</span>
        </h2>
        <p>Explore highlights and research from our previous conferences.</p>
      </div>

      <div class="events-grid">
        {
          pastEvents.map((event, index) => (
            <div class={`animate-fade-up delay-${(index + 1) * 100}`}>
              <EventCard {...event} />
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section id="network" class="section network-section">
    <div class="container network-container">
      <div class="network-content animate-fade-up">
        <h2>Our <span class="text-gradient">Aims</span></h2>
        <p>
          We facilitate communication and collaboration among industrial
          economists from academia, government, and industry. Our goal is to
          promote the exchange of ideas through conferences and workshops,
          provide a forum for discussing current challenges, support new
          research and teaching development, and promote diversity, inclusion,
          and the professional growth of our network members.
        </p>

        <div class="subscribe-form">
          <a
            href="https://groups.google.com/g/network-of-industrial-economists"
            target="_blank"
            rel="noopener"
            class="btn btn-primary"
            style="margin: 0 auto;">Join Network</a
          >
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .section-title {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }

  .lead {
    font-size: 1.15rem;
    color: var(--text-primary);
    font-weight: 500;
  }

  /* About Section */
  .about-section {
    position: relative;
    background: linear-gradient(to bottom, transparent, rgba(15, 23, 42, 0.4));
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-top: 3rem;
  }

  .stat-box {
    padding: 1.5rem;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: var(--border-radius-md);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    transition:
      transform 0.3s ease,
      background 0.3s ease;
  }

  .stat-box:hover {
    transform: translateY(-5px);
    background: rgba(255, 255, 255, 0.05);
    border-color: rgba(59, 130, 246, 0.3);
  }

  .stat-number {
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--text-primary);
    font-family: var(--font-heading);
    margin-bottom: 0.5rem;
  }

  .stat-label {
    font-size: 0.85rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 1px;
    font-weight: 600;
  }

  /* Abstract Data Visual */
  .about-visual {
    position: relative;
  }

  .glass-panel {
    background: var(--bg-card);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: var(--border-radius-lg);
    padding: 3rem;
    height: 400px;
    position: relative;
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
    overflow: hidden;
  }

  .glass-panel::before {
    content: "";
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(
      circle at center,
      rgba(59, 130, 246, 0.1) 0%,
      transparent 50%
    );
    animation: rotate 20s linear infinite;
  }

  @keyframes rotate {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }

  .chart-bars {
    position: absolute;
    bottom: 3rem;
    left: 3rem;
    right: 3rem;
    height: 200px;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
    z-index: 2;
  }

  .bar {
    flex: 1;
    background: linear-gradient(
      to top,
      rgba(59, 130, 246, 0.2),
      rgba(59, 130, 246, 0.8)
    );
    border-radius: 4px 4px 0 0;
    animation: grow 2s ease-out forwards;
    transform-origin: bottom;
  }

  .b1 {
    height: 40%;
    animation-delay: 0.2s;
  }
  .b2 {
    height: 65%;
    animation-delay: 0.4s;
  }
  .b3 {
    height: 50%;
    animation-delay: 0.6s;
  }
  .b4 {
    height: 85%;
    animation-delay: 0.8s;
  }
  .b5 {
    height: 75%;
    animation-delay: 1s;
  }

  @keyframes grow {
    from {
      transform: scaleY(0);
    }
    to {
      transform: scaleY(1);
    }
  }

  /* Events Section */
  .events-section {
    padding-top: 2rem;
  }

  .past-events-section {
    padding-top: 4rem;
    padding-bottom: 4rem;
    background: rgba(255, 255, 255, 0.02);
  }

  .section-header {
    text-align: center;
    margin-bottom: 4rem;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .events-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 2rem;
  }

  .events-action {
    text-align: center;
    margin-top: 4rem;
  }

  /* Network Section */
  .network-section {
    margin-bottom: 3rem;
  }

  .network-container {
    background:
      radial-gradient(
        circle at right center,
        rgba(139, 92, 246, 0.15) 0%,
        transparent 50%
      ),
      rgba(15, 23, 42, 0.6);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: var(--border-radius-lg);
    padding: 5rem 3rem;
    text-align: center;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  .network-content {
    max-width: 600px;
    margin: 0 auto;
  }

  .network-content h2 {
    font-size: 2.2rem;
  }

  .subscribe-form {
    margin-top: 2.5rem;
    display: flex;
    gap: 1rem;
    max-width: 500px;
    margin-left: auto;
    margin-right: auto;
  }

  .email-input {
    flex: 1;
    padding: 0.8rem 1.5rem;
    border-radius: 50px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(0, 0, 0, 0.3);
    color: var(--text-primary);
    font-family: var(--font-base);
    font-size: 1rem;
  }

  .email-input:focus {
    outline: none;
    border-color: var(--accent-primary);
    box-shadow: 0 0 10px rgba(59, 130, 246, 0.2);
  }

  .subscribe-form .btn {
    border-radius: 50px;
    padding: 0.8rem 2rem;
  }

  @media (max-width: 992px) {
    .about-grid {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .stats-grid {
      justify-content: center;
    }
    .about-visual {
      display: none; /* Hide complex visual on smaller screens for simplicity */
    }
  }

  @media (max-width: 768px) {
    .subscribe-form {
      flex-direction: column;
    }
  }
</style>
