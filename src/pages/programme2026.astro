---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="NIE ECR Symposium 2026 – Programme"
  description="Full programme for the 2026 NIE Early Career Researcher Symposium, June 25 at the University of Sheffield."
>
  <div class="container page-container">
    <div class="animate-fade-up">
      <div class="badge">June 25, 2026</div>
      <h1 class="page-title">
        ECR Symposium <span class="text-gradient">Programme</span>
      </h1>
      <div class="glass-card main-info">
        <p class="lead">
          Network of Industrial Economists <strong>Early Career Researcher Symposium</strong>.
          Sponsored by <strong>Charles River Associates</strong> — including the
          RSS Best Paper Prize awarded at the close of the day.
        </p>
        <div class="meta-item">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18"
            viewBox="0 0 24 24" fill="none" stroke="currentColor"
            stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
            class="icon">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
            <circle cx="12" cy="10" r="3"></circle>
          </svg>
          <span><strong>Venue:</strong> The Wave, University of Sheffield School of Economics</span>
        </div>
      </div>
    </div>

    <div class="legend animate-fade-up delay-100">
      <span class="legend-item tag-industrial">Industrial Policy</span>
      <span class="legend-item tag-environment">Environment</span>
      <span class="legend-item tag-cra">CRA · Competition</span>
      <span class="legend-item tag-ai">AI &amp; Market Efficiency</span>
    </div>

    <div class="schedule animate-fade-up delay-200">

      <!-- Registration -->
      <div class="row row-admin">
        <div class="time-col"><span class="time-label">09:00</span></div>
        <div class="content-col">
          <span class="admin-label">Registration – ECR Symposium</span>
        </div>
      </div>

      <!-- Welcome -->
      <div class="row row-welcome">
        <div class="time-col"><span class="time-label">09:20</span></div>
        <div class="content-col">
          <span class="welcome-label">Welcome &amp; Opening Remarks</span>
        </div>
      </div>

      <!-- Section: Industrial Policy -->
      <div class="row row-section">
        <div class="time-col"></div>
        <div class="content-col">
          <span class="section-tag tag-industrial">Industrial Policy</span>
        </div>
      </div>

      <div class="row row-block">
        <div class="time-col"><span class="time-label">09:30–11:00</span></div>
        <div class="content-col">
          <div class="block-wrapper">
            <div class="speaker-row">
              <div class="speaker-name">Rhys Williams</div>
              <div class="speaker-title">Who Gets the Dough? Explaining the Gluten Free Price Premium</div>
              <div class="speaker-affiliation">University of Cambridge</div>
            </div>
          </div>
          <div class="block-wrapper">
            <div class="speaker-row">
              <div class="speaker-name">Yuxuan Liu</div>
              <div class="speaker-title">Flood Risk and House Prices: Evidence from the UK Housing Market</div>
              <div class="speaker-affiliation">University of Sheffield</div>
            </div>
          </div>
          <div class="block-wrapper">
            <div class="speaker-row">
              <div class="speaker-name">Glory Okutue</div>
              <div class="speaker-title">The Trade Task after Brexit: Evidence from UK Vacancy Data</div>
              <div class="speaker-affiliation">University of Nottingham</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Coffee -->
      <div class="row row-admin">
        <div class="time-col"><span class="time-label">11:00</span></div>
        <div class="content-col"><span class="admin-label">Coffee Break – 15 min</span></div>
      </div>

      <!-- Section: Environment -->
      <div class="row row-section">
        <div class="time-col"></div>
        <div class="content-col">
          <span class="section-tag tag-environment">Environment</span>
        </div>
      </div>

      <div class="row row-block">
        <div class="time-col"><span class="time-label">11:15–12:45</span></div>
        <div class="content-col">
          <div class="block-wrapper">
            <div class="speaker-row">
              <div class="speaker-name">Antonio Fuso</div>
              <div class="speaker-title">Determinants of Renewable Energy Community Diffusion: A Spatial Econometric Analysis of Italian Municipalities</div>
              <div class="speaker-affiliation">University of Bari</div>
            </div>
          </div>
          <div class="block-wrapper">
            <div class="speaker-row">
              <div class="speaker-name">Sébastien Montpetit</div>
              <div class="speaker-title">Are Climate Policies Marginal? A Welfare Evaluation of Environmental Reforms</div>
              <div class="speaker-affiliation">University of Warwick</div>
            </div>
          </div>
          <div class="block-wrapper">
            <div class="speaker-row">
              <div class="speaker-name">Zhenyu Fu</div>
              <div class="speaker-title">Do ESG Ratings Reflect Corporate Carbon Performance? Evidence from UK-Listed Firms</div>
              <div class="speaker-affiliation">University of Nottingham</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Lunch -->
      <div class="row row-admin">
        <div class="time-col"><span class="time-label">12:45</span></div>
        <div class="content-col"><span class="admin-label">Lunch Break – 60 min</span></div>
      </div>

      <!-- Section: CRA -->
      <div class="row row-section">
        <div class="time-col"></div>
        <div class="content-col">
          <span class="section-tag tag-cra">CRA Session · Competition</span>
        </div>
      </div>

      <div class="row row-block">
        <div class="time-col"><span class="time-label">13:45–14:15</span></div>
        <div class="content-col">
          <div class="block-wrapper cra-block">
            <div class="cra-eyebrow">Charles River Associates</div>
            <div class="speaker-name">Ignacio Núñez</div>
            <div class="speaker-title">Market Allocation in Differentiated Bertrand Competition</div>
            <div class="speaker-affiliation">Charles River Associates</div>
          </div>
        </div>
      </div>

      <!-- Section: AI -->
      <div class="row row-section">
        <div class="time-col"></div>
        <div class="content-col">
          <span class="section-tag tag-ai">AI &amp; Market Efficiency</span>
        </div>
      </div>

      <div class="row row-block">
        <div class="time-col"><span class="time-label">14:15–15:45</span></div>
        <div class="content-col">
          <div class="block-wrapper">
            <div class="speaker-row">
              <div class="speaker-name">Fengxiang He</div>
              <div class="speaker-title">Rationality Measurement and Theory for Reinforcement Learning Agents</div>
              <div class="speaker-affiliation">University of Edinburgh</div>
            </div>
          </div>
          <div class="block-wrapper">
            <div class="speaker-row">
              <div class="speaker-name">Domenika Ušková</div>
              <div class="speaker-title">When Peers Fail: Data Breach Signals and the Competitive Advantage of Non-Breached Firms</div>
              <div class="speaker-affiliation">University of Warwick</div>
            </div>
          </div>
          <div class="block-wrapper">
            <div class="speaker-row">
              <div class="speaker-name">Ivan Rendo</div>
              <div class="speaker-title">Excessive Content Moderation</div>
              <div class="speaker-affiliation">University of Toulouse</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Award -->
      <div class="row row-admin">
        <div class="time-col"><span class="time-label">15:45</span></div>
        <div class="content-col">
          <span class="award-label">RSS Best Paper Award &amp; Concluding Remarks</span>
        </div>
      </div>

    </div><!-- /.schedule -->

    <div class="sponsor-row animate-fade-up delay-300">
      <p>Generously sponsored by</p>
      <img src="/images/NIE2026/CRA.png" alt="Charles River Associates" />
    </div>

  </div>
</Layout>

<style>
  /* ── Page shell ─────────────────────────────────────────── */
  .page-container {
    padding-top: 6rem;
    padding-bottom: 6rem;
  }

  .badge {
    display: inline-block;
    padding: 0.5rem 1rem;
    background: rgba(59, 130, 246, 0.1);
    border: 1px solid rgba(59, 130, 246, 0.2);
    border-radius: 50px;
    color: var(--accent-secondary);
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 1rem;
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  .page-title {
    font-size: clamp(2.2rem, 4vw, 3.2rem);
    margin-bottom: 2rem;
  }

  .glass-card {
    background: var(--bg-card);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: var(--border-radius-md);
    padding: 2rem;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    margin-bottom: 2rem;
  }

  .main-info {
    border-left: 4px solid var(--accent-primary);
  }

  .meta-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 1rem;
    color: var(--text-secondary);
  }

  .icon { color: var(--accent-secondary); }

  /* ── Legend ─────────────────────────────────────────────── */
  .legend {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }

  .legend-item {
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 600;
    padding: 4px 12px;
    border-radius: 4px;
  }

  /* ── Section tags & legend shared colours ───────────────── */
  .tag-industrial {
    background: rgba(59, 130, 246, 0.15);
    color: #93c5fd;
    border: 1px solid rgba(59, 130, 246, 0.3);
  }

  .tag-environment {
    background: rgba(52, 211, 153, 0.1);
    color: #6ee7b7;
    border: 1px solid rgba(52, 211, 153, 0.25);
  }

  .tag-cra {
    background: rgba(251, 191, 36, 0.1);
    color: #fcd34d;
    border: 1px solid rgba(251, 191, 36, 0.25);
  }

  .tag-ai {
    background: rgba(139, 92, 246, 0.15);
    color: #c4b5fd;
    border: 1px solid rgba(139, 92, 246, 0.3);
  }

  /* ── Schedule grid ──────────────────────────────────────── */
  .schedule {
    display: flex;
    flex-direction: column;
    gap: 3px;
    margin-bottom: 3rem;
  }

  .row {
    display: grid;
    grid-template-columns: 100px 1fr;
  }

  .time-col {
    padding: 14px 16px 14px 0;
    display: flex;
    align-items: flex-start;
    justify-content: flex-end;
  }

  .time-label {
    font-family: 'Courier New', 'Lucida Console', monospace;
    font-size: 10px;
    color: var(--text-muted);
    letter-spacing: 0.04em;
    padding-top: 2px;
    white-space: nowrap;
  }

  .content-col {
    border-left: 1px solid var(--divider);
    padding: 12px 0 12px 20px;
  }

  /* Admin rows */
  .row-admin .content-col {
    display: flex;
    align-items: center;
  }

  .admin-label {
    font-family: 'Courier New', monospace;
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--divider);
    border-radius: 4px;
    padding: 5px 12px;
  }

  .award-label {
    font-family: 'Courier New', monospace;
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #b45309;
    background: transparent;
    border: 1px solid rgba(180, 83, 9, 0.4);
    border-radius: 4px;
    padding: 5px 12px;
  }

  [data-theme="dark"] .award-label {
    color: #fcd34d;
    border-color: rgba(251, 191, 36, 0.35);
  }

  /* Welcome row */
  .row-welcome .content-col {
    display: flex;
    align-items: center;
  }

  .welcome-label {
    font-family: var(--font-heading);
    font-style: italic;
    font-size: 0.95rem;
    color: var(--text-secondary);
  }

  /* Section header rows */
  .row-section .content-col {
    padding-top: 24px;
    padding-bottom: 6px;
  }

  .section-tag {
    display: inline-block;
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 600;
    padding: 4px 12px;
    border-radius: 4px;
  }

  /* Speaker block rows */
  .row-block .content-col {
    padding-top: 0;
    padding-bottom: 0;
  }

  .block-wrapper {
    background: var(--bg-card);
    border: 1px solid var(--divider);
    border-radius: var(--border-radius-sm);
    overflow: hidden;
    margin-bottom: 4px;
    transition: border-color 0.2s ease, background 0.2s ease;
  }

  .block-wrapper:last-child { margin-bottom: 0; }

  .block-wrapper:hover {
    background: var(--bg-card-hover);
    border-color: rgba(255, 255, 255, 0.12);
  }

  .speaker-row {
    padding: 14px 18px;
  }

  .speaker-name {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--text-primary);
    margin-bottom: 4px;
  }

  .speaker-title {
    font-size: 0.95rem;
    font-style: italic;
    color: var(--text-secondary);
    line-height: 1.45;
    margin-bottom: 6px;
  }

  .speaker-affiliation {
    font-family: 'Courier New', monospace;
    font-size: 9.5px;
    color: var(--text-muted);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  /* CRA block special styling */
  .cra-block {
    background: var(--bg-card);
    border: 1px solid rgba(251, 191, 36, 0.35) !important;
    border-left: 3px solid #f59e0b !important;
    border-radius: var(--border-radius-sm);
    padding: 16px 18px;
  }

  .cra-block:hover {
    background: var(--bg-card-hover) !important;
  }

  .cra-eyebrow {
    font-family: 'Courier New', monospace;
    font-size: 9px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #b45309;
    margin-bottom: 8px;
  }

  [data-theme="dark"] .cra-eyebrow {
    color: #fcd34d;
  }

  .cra-block .speaker-name { color: var(--text-primary); }

  /* ── Sponsor footer ─────────────────────────────────────── */
  .sponsor-row {
    display: flex;
    align-items: center;
    gap: 1.2rem;
    margin-top: 1rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--divider);
  }

  .sponsor-row p {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin: 0;
    font-style: italic;
  }

  .sponsor-row img {
    max-height: 44px;
    object-fit: contain;
    opacity: 0.8;
  }

  /* ── Responsive ─────────────────────────────────────────── */
  @media (max-width: 560px) {
    .row {
      grid-template-columns: 68px 1fr;
    }

    .time-label {
      font-size: 9px;
    }

    .content-col {
      padding-left: 14px;
    }
  }
</style>
