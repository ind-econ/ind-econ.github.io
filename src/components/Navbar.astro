---
const currentPath = Astro.url.pathname;
const navItems = [
  { path: '/', label: 'Home' },
  { path: '/about', label: 'About' },
  { path: '/#upcoming-events', label: 'Events' }
];
---

<header class="navbar">
  <div class="container nav-container">
    <a href="/" class="logo">
      <span class="logo-text">NIE</span>
      <span class="logo-dot"></span>
    </a>
    <nav class="nav-links">
      {navItems.map(item => (
        <a 
          href={item.path} 
          class={`nav-link ${currentPath === item.path ? 'active' : ''}`}
        >
          {item.label}
        </a>
      ))}
    </nav>
    <a href="https://groups.google.com/g/network-of-industrial-economists" target="_blank" rel="noopener" class="btn btn-primary">Join Network</a>
  </div>
</header>

<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 100;
    background: rgba(5, 9, 20, 0.7);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--divider);
    padding: 1rem 0;
  }

  .nav-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    display: flex;
    align-items: baseline;
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text-primary);
  }

  .logo-text {
    letter-spacing: 1px;
  }

  .logo-dot {
    width: 8px;
    height: 8px;
    background-color: var(--accent-primary);
    border-radius: 50%;
    margin-left: 2px;
    box-shadow: 0 0 10px var(--accent-glow);
    animation: pulse 2s infinite ease-in-out;
  }

  @keyframes pulse {
    0%, 100% {
      transform: scale(1);
      opacity: 1;
      box-shadow: 0 0 10px var(--accent-glow);
    }
    50% {
      transform: scale(1.5);
      opacity: 0.8;
      box-shadow: 0 0 20px var(--accent-glow);
    }
  }

  .nav-links {
    display: flex;
    gap: 2rem;
  }

  .nav-link {
    color: var(--text-secondary);
    font-size: 0.95rem;
    font-weight: 500;
    position: relative;
    padding: 0.5rem 0;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0%;
    height: 2px;
    background: var(--accent-primary);
    transition: width 0.3s ease;
  }

  .nav-link:hover, .nav-link.active {
    color: var(--text-primary);
    text-decoration: none;
  }

  .nav-link:hover::after, .nav-link.active::after {
    width: 100%;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.6rem 1.2rem;
    font-weight: 600;
    font-size: 0.9rem;
    border-radius: var(--border-radius-sm);
    transition: all 0.3s ease;
    cursor: pointer;
    font-family: var(--font-base);
  }

  .btn-primary {
    background: var(--accent-primary);
    color: white;
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow: 0 0 15px rgba(59, 130, 246, 0.3);
  }

  .btn-primary:hover {
    background: var(--accent-secondary);
    color: white;
    text-decoration: none;
    transform: translateY(-2px);
    box-shadow: 0 0 25px rgba(59, 130, 246, 0.5);
  }

  @media (max-width: 768px) {
    .nav-links {
      display: none; /* In a full app, implement a hamburger menu here */
    }
  }
</style>
